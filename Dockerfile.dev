FROM rust:1.94-alpine

# Install build tools and dependencies (OpenSSL, MySQL client dev headers, curl for rustup)
RUN apk add --no-cache \
    bash \
    ca-certificates \
    openssl-dev \
    mysql-client \
    mysql-dev \
    build-base \
    pkgconfig \
    musl-dev \
    linux-headers

# Use the Rust toolchain provided by the base image (1.94); install cargo-watch
RUN cargo install cargo-watch

WORKDIR /usr/src/app

# Source will be mounted by docker-compose for live edits.
EXPOSE 3001
CMD ["cargo", "watch", "-x", "run"]
